<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    <main class="container mx-auto px-4 py-10 max-w-5xl">
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
        <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-80 object-cover">
        <div class="p-8">
          <h2 class="text-3xl font-bold text-gray-800 mb-2"><%= home.houseName %></h2>
          <p class="text-gray-500 flex items-center gap-1 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-teal-500">
              <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.083 3.898-5.067 3.898-9.185a8.25 8.25 0 00-16.5 0c0 4.117 1.954 7.1 3.898 9.185a19.576 19.576 0 002.683 2.282 16.975 16.975 0 001.144.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
            </svg>
            <%= home.location %>
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-gray-50 rounded-xl p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Price</p>
              <p class="text-2xl font-bold text-teal-600">$<%= home.price %><span class="text-sm font-normal text-gray-400"> / night</span></p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Rating</p>
              <div class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-yellow-400">
                  <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd"/>
                </svg>
                <span class="text-xl font-bold text-gray-700"><%= home.rating %></span>
                <span class="text-gray-400 text-sm">/ 5</span>
              </div>
            </div>
            <div class="bg-gray-50 rounded-xl p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Type</p>
              <p class="text-lg font-semibold text-gray-700">Entire Home</p>
            </div>
          </div>

          <% if (home.description) { %>
          <div class="mb-8">
            <h3 class="text-xl font-semibold text-gray-700 mb-3">About this place</h3>
            <p class="text-gray-600 leading-relaxed"><%= home.description %></p>
          </div>
          <% } %>

          <div class="flex flex-wrap gap-3">
            <% if (isLoggedIn && user && user.userType === 'guest') { %>
              <form action="/bookings" method="POST">
                <input type="hidden" name="id" value="<%= home._id %>">
                <button type="submit"
                  class="bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 px-8 rounded-xl transition duration-200 flex items-center gap-2 shadow-md">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                    <path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" clip-rule="evenodd"/>
                  </svg>
                  Book Now
                </button>
              </form>
              <%- include('../partials/favourite') %>
            <% } else if (!isLoggedIn) { %>
              <a href="/login"
                class="bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 px-8 rounded-xl transition duration-200 shadow-md">
                Log in to Book
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
