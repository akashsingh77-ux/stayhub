<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    <main class="container mx-auto px-4 py-10 max-w-6xl">
      <div class="text-center mb-10">
        <h2 class="text-4xl font-bold text-teal-700 mb-2">Browse All Homes</h2>
        <p class="text-gray-500">Find the perfect place to stay</p>
      </div>
      <div class="flex flex-wrap justify-center gap-6">
        <% registeredHomes.forEach(home => { %>
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition duration-300 w-full max-w-sm flex flex-col">
            <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-52 object-cover">
            <div class="p-5 flex flex-col flex-1">
              <h3 class="text-xl font-semibold text-gray-800 mb-1"><%= home.houseName %></h3>
              <p class="text-gray-500 text-sm mb-3 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-teal-500"><path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.083 3.898-5.067 3.898-9.185a8.25 8.25 0 00-16.5 0c0 4.117 1.954 7.1 3.898 9.185a19.576 19.576 0 002.683 2.282 16.975 16.975 0 001.144.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/></svg>
                <%= home.location %>
              </p>
              <div class="flex justify-between items-center mb-4">
                <span class="text-lg font-bold text-teal-600">Rs <%= home.price %><span class="text-gray-400 font-normal text-sm"> / night</span></span>
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-yellow-400">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-gray-600 text-sm font-medium"><%= home.rating %></span>
                </div>
              </div>
              <div class="flex gap-2 mt-auto">
                <a href="/homes/<%= home._id %>"
                  class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2 px-4 rounded-lg transition duration-200 text-center text-sm">
                  View Details
                </a>
                <%- include('../partials/favourite', {home: home}) %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </main>
  </body>
</html>
