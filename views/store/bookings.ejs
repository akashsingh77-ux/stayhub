<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    <main class="container mx-auto px-4 py-10 max-w-6xl">
      <div class="text-center mb-10">
        <h2 class="text-4xl font-bold text-teal-700 mb-2">My Bookings</h2>
        <p class="text-gray-500">All your reserved stays in one place</p>
      </div>

      <% if (!bookedHomes || bookedHomes.length === 0) { %>
        <div class="text-center py-20">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-16 h-16 text-teal-200 mx-auto mb-4">
            <path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" clip-rule="evenodd"/>
          </svg>
          <p class="text-2xl text-gray-400 font-semibold mb-4">No bookings yet</p>
          <a href="/" class="bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 px-8 rounded-xl transition duration-200 inline-block shadow">
            Explore Homes
          </a>
        </div>
      <% } else { %>
        <div class="flex flex-wrap justify-center gap-6">
          <% bookedHomes.forEach(home => { %>
            <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition duration-300 w-full max-w-sm flex flex-col">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-48 object-cover">
              <div class="p-5 flex flex-col flex-1">
                <h3 class="text-xl font-semibold text-gray-800 mb-1"><%= home.houseName %></h3>
                <p class="text-gray-500 text-sm mb-3 flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-teal-500">
                    <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.083 3.898-5.067 3.898-9.185a8.25 8.25 0 00-16.5 0c0 4.117 1.954 7.1 3.898 9.185a19.576 19.576 0 002.683 2.282 16.975 16.975 0 001.144.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
                  </svg>
                  <%= home.location %>
                </p>
                <div class="flex justify-between items-center mb-4">
                  <span class="text-lg font-bold text-teal-600">Rs<%= home.price %><span class="text-gray-400 font-normal text-sm"> / night</span></span>
                  <span class="bg-teal-50 text-teal-700 text-xs font-semibold px-3 py-1 rounded-full">Booked ✓</span>
                </div>
                <form action="/bookings/delete/<%= home._id %>" method="POST" class="mt-auto">
                  <button type="submit"
                    class="w-full bg-red-50 hover:bg-red-100 text-red-600 border border-red-200 font-semibold py-2 px-4 rounded-lg transition duration-200 text-sm">
                    Cancel Booking
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </main>
  </body>
</html>
