<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    <main class="container mx-auto px-4 py-10 max-w-6xl">
      <div class="text-center mb-10">
        <h2 class="text-4xl font-bold text-teal-700 mb-2">My Saved Homes</h2>
        <p class="text-gray-500">Places you've saved for later</p>
      </div>

      <% if (!favouriteHomes || favouriteHomes.length === 0) { %>
        <div class="text-center py-20">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-16 h-16 text-rose-200 mx-auto mb-4">
            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/>
          </svg>
          <p class="text-2xl text-gray-400 font-semibold mb-4">No saved homes yet</p>
          <a href="/homes" class="bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 px-8 rounded-xl transition duration-200 inline-block shadow">
            Browse Homes
          </a>
        </div>
      <% } else { %>
        <div class="flex flex-wrap justify-center gap-6">
          <% favouriteHomes.forEach(home => { %>
            <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition duration-300 w-full max-w-sm flex flex-col">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-48 object-cover">
              <div class="p-5 flex flex-col flex-1">
                <h3 class="text-xl font-semibold text-gray-800 mb-1"><%= home.houseName %></h3>
                <p class="text-gray-500 text-sm mb-3 flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-teal-500">
                    <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.083 3.898-5.067 3.898-9.185a8.25 8.25 0 00-16.5 0c0 4.117 1.954 7.1 3.898 9.185a19.576 19.576 0 002.683 2.282 16.975 16.975 0 001.144.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
                  </svg>
                  <%= home.location %>
                </p>
                <div class="flex justify-between items-center mb-4">
                  <span class="text-lg font-bold text-teal-600">Rs <%= home.price %><span class="text-gray-400 font-normal text-sm"> / night</span></span>
                  <div class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-yellow-400">
                      <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-600 text-sm"><%= home.rating %></span>
                  </div>
                </div>
                <div class="flex gap-2 mt-auto">
                  <form action="/bookings" method="POST" class="flex-1">
                    <input type="hidden" name="id" value="<%= home._id %>">
                    <button type="submit"
                      class="w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200 text-sm">
                      Book Now
                    </button>
                  </form>
                  <form action="/favourites/delete/<%= home._id %>" method="POST" class="flex-1">
                    <button type="submit"
                      class="w-full bg-red-50 hover:bg-red-100 text-red-600 border border-red-200 font-semibold py-2 px-4 rounded-lg transition duration-200 text-sm">
                      Remove
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </main>
  </body>
</html>
