<header class="bg-teal-600 text-white p-4 shadow-md sticky top-0 z-10">
  <nav class="container mx-auto">
    <!-- Desktop Navigation -->
    <div class="hidden md:flex md:justify-between md:items-center">
      <ul class="flex items-center flex-wrap gap-1">
        <li>
          <a href="/"
            class="<%= currentPage === 'index' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-4 rounded-lg transition duration-300 flex items-center gap-1 text-lg font-bold tracking-wide">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
              <path d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z"/>
              <path d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z"/>
            </svg>
            StayHub
          </a>
        </li>

        <% if (isLoggedIn) { %>
          <% if (user && user.userType === 'guest') { %>
            <li>
              <a href="/homes"
                class="<%= currentPage === 'Home' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-4 rounded-lg transition duration-300 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M3.019 11.115L18 5.667V9.09l4.006 1.456a.75.75 0 11-.512 1.41l-.494-.18v8.475h.75a.75.75 0 010 1.5H2.25a.75.75 0 010-1.5H3v-9.129l.019-.006zM18 20.25v-9.565l1.5.545v9.02H18zm-9-6a.75.75 0 00-.75.75v4.5c0 .414.336.75.75.75h3a.75.75 0 00.75-.75V15a.75.75 0 00-.75-.75H9z" clip-rule="evenodd"/>
                </svg>
                Homes
              </a>
            </li>
            <li>
              <a href="/favourites"
                class="<%= currentPage === 'favourites' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-4 rounded-lg transition duration-300 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                  <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/>
                </svg>
                Favourites
              </a>
            </li>
            <li>
              <a href="/bookings"
                class="<%= currentPage === 'bookings' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-4 rounded-lg transition duration-300 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" clip-rule="evenodd"/>
                </svg>
                My Bookings
              </a>
            </li>
          <% } else { %>
            <li>
              <a href="/host/host-home-list"
                class="<%= currentPage === 'host-homes' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-4 rounded-lg transition duration-300 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M3 20.25v-8.755c1.42.674 3.08.673 4.5 0A5.234 5.234 0 009.75 12c.804 0 1.568-.182 2.25-.506a5.234 5.234 0 002.25.506c.804 0 1.567-.182 2.25-.506 1.42.674 3.08.675 4.5.001v8.755h.75a.75.75 0 010 1.5H2.25a.75.75 0 010-1.5H3zm3-6a.75.75 0 01.75-.75h3a.75.75 0 01.75.75v3a.75.75 0 01-.75.75h-3a.75.75 0 01-.75-.75v-3zm8.25-.75a.75.75 0 00-.75.75v5.25c0 .414.336.75.75.75h3a.75.75 0 00.75-.75v-5.25a.75.75 0 00-.75-.75h-3z" clip-rule="evenodd"/>
                </svg>
                My Listings
              </a>
            </li>
            <li>
              <a href="/host/add-home"
                class="<%= currentPage === 'addHome' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-4 rounded-lg transition duration-300 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M12 3.75a.75.75 0 01.75.75v6.75h6.75a.75.75 0 010 1.5h-6.75v6.75a.75.75 0 01-1.5 0v-6.75H4.5a.75.75 0 010-1.5h6.75V4.5a.75.75 0 01.75-.75z" clip-rule="evenodd"/>
                </svg>
                Add Listing
              </a>
            </li>
          <% } %>
        <% } %>
      </ul>

      <ul class="flex items-center gap-2">
        <% if (!isLoggedIn) { %>
        <li>
          <a href="/signup"
            class="<%= currentPage === 'signup' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-5 rounded-lg transition duration-300 border border-white font-medium">
            Sign Up
          </a>
        </li>
        <li>
          <a href="/login"
            class="bg-white text-teal-600 hover:bg-teal-50 py-2 px-5 rounded-lg transition duration-300 font-semibold shadow">
            Log In
          </a>
        </li>
        <% } else { %>
        <li class="text-teal-100 text-sm mr-1">
          Hi, <%= user ? user.firstName : '' %>
        </li>
        <li>
          <form action="/logout" method="POST">
            <button type="submit"
              class="hover:bg-teal-500 py-2 px-4 rounded-lg transition duration-300 border border-white flex items-center gap-1 font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                <path fill-rule="evenodd" d="M7.5 3.75A1.5 1.5 0 006 5.25v13.5a1.5 1.5 0 001.5 1.5h6a1.5 1.5 0 001.5-1.5V15a.75.75 0 011.5 0v3.75a3 3 0 01-3 3h-6a3 3 0 01-3-3V5.25a3 3 0 013-3h6a3 3 0 013 3V9A.75.75 0 0115 9V5.25a1.5 1.5 0 00-1.5-1.5h-6zm5.03 4.72a.75.75 0 010 1.06l-1.72 1.72h10.94a.75.75 0 010 1.5H10.81l1.72 1.72a.75.75 0 11-1.06 1.06l-3-3a.75.75 0 010-1.06l3-3a.75.75 0 011.06 0z" clip-rule="evenodd"/>
              </svg>
              Logout
            </button>
          </form>
        </li>
        <% } %>
      </ul>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden">
      <div class="flex justify-between items-center">
        <a href="/" class="flex items-center gap-1 py-2 px-3 rounded-lg font-bold text-lg <%= currentPage === 'index' ? 'bg-teal-800' : '' %>">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
            <path d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z"/>
            <path d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z"/>
          </svg>
          StayHub
        </a>
        <button id="mobile-menu-button" class="p-2 rounded-lg hover:bg-teal-500">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
          </svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden mt-2">
        <ul class="flex flex-col space-y-1 border-t border-teal-500 pt-2 mt-2">
          <% if (isLoggedIn) { %>
          <li><a href="/homes" class="<%= currentPage === 'Home' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-3 rounded-lg flex items-center">Homes</a></li>
          <li><a href="/favourites" class="<%= currentPage === 'favourites' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-3 rounded-lg flex items-center">Favourites</a></li>
          <li><a href="/bookings" class="<%= currentPage === 'bookings' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-3 rounded-lg flex items-center">My Bookings</a></li>
          <li><a href="/host/host-home-list" class="<%= currentPage === 'host-homes' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-3 rounded-lg flex items-center">My Listings</a></li>
          <li><a href="/host/add-home" class="<%= currentPage === 'addHome' ? 'bg-teal-800 font-semibold' : 'hover:bg-teal-500' %> py-2 px-3 rounded-lg flex items-center">Add Listing</a></li>
          <li class="pt-2 border-t border-teal-500 mt-2">
            <form action="/logout" method="POST">
              <button type="submit" class="hover:bg-teal-500 py-2 px-3 rounded-lg w-full text-left flex items-center">Logout</button>
            </form>
          </li>
          <% } else { %>
          <li><a href="/signup" class="hover:bg-teal-500 py-2 px-3 rounded-lg block">Sign Up</a></li>
          <li><a href="/login" class="bg-white text-teal-600 hover:bg-teal-50 py-2 px-3 rounded-lg block mt-2 font-semibold">Log In</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
</header>

<script>
  document.getElementById("mobile-menu-button")?.addEventListener("click", function () {
    document.getElementById("mobile-menu").classList.toggle("hidden");
  });
</script>
